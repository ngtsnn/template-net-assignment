{
  "name": "my-express-app",
  "version": "1.0.0",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development npx tsx watch src/server.ts",
    "build": "tsc && tsc-alias",
    "start": "cross-env NODE_ENV=production node dist/server.js",
    "typecheck": "tsc --noEmit",
    "format:check": "npx prettier . --check",
    "format:fix": "npx prettier . --write",
    "swagger:generate": "npx swagger-autogen -i src/swagger.config.ts -o docs/swagger.json"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.41",
    "@google/genai": "^1.44.0",
    "ai": "^6.0.116",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.9.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "cross-env": "^10.1.0",
    "dotenv-flow": "^4.1.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.0",
    "groq-sdk": "^0.37.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.2.4",
    "multer": "^2.1.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "source-map-support": "^0.5.21",
    "swagger-autogen": "^2.23.7",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/helmet": "^0.0.48",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.3.5",
    "@types/source-map-support": "^0.5.10",
    "@types/swagger-ui-express": "^4.1.8",
    "lint-staged": "^16.3.2",
    "morgan": "^1.10.1",
    "prettier": "^3.8.1",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
